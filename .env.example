# ローカルで npm run dev を使うと scripts/dev-server.mjs が .env.local を読み、静的 + /api/* を同一ポートで提供します。

# --- お問い合わせ → Supabase（/api/contact-inquiry）推奨: service_role は Vercel のみ ---
# SUPABASE_URL の場所: Supabase Dashboard（https://supabase.com/dashboard）→ 対象プロジェクト →
#   Settings（歯車）→ API →「Project URL」
#   例: https://abcdefghijklmnop.supabase.co（末尾は .supabase.co。/rest/v1 は付けない）
# ホストまで（…supabase.co）。/rest/v1 は含めない（API が付与するが、含めてもサーバーで除去する）
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# 新規登録（/api/auth-sign-up）に必須。anon では代用不可。例ファイルには実キーを書かない（.env.local のみ）。
# Invalid API key → URL と service_role が同一プロジェクトか、全文コピーか、Preview にも変数があるか確認
# ログイン API（/api/auth-sign-in）で signInWithPassword に使用。ブラウザへは出さずサーバーのみに設定。
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# 新規登録でメール確認をスキップする場合（開発用）。未設定または false のときは Supabase の既定（多くは確認メールあり）。
# SUPABASE_AUTH_EMAIL_AUTO_CONFIRM=true

# --- お問い合わせ一覧（GET /api/contact-inquiries-admin・contact-inquiries-admin.html）---
# 長いランダム文字列を生成し、Vercel に設定したうえで一覧ページの「管理者トークン」に同じ値を入力する
# CONTACT_INQUIRIES_ADMIN_SECRET=

# --- ターミナルから psql で接続（scripts/sql-shell.sh）※ DB パスワードを含むため .env.local のみ推奨 ---
# Supabase Dashboard → Settings → Database → Connection string → URI
# Session pooler（IPv4 可）の例: ホストは pooler.supabase.com、ユーザーは postgres.<project-ref>、ポートは多くの場合 5432
# export SUPABASE_DATABASE_URL='postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres'
# 認証だけ失敗するとき（パスワードに記号がある等）: 平文を別変数にし、URI から :password を外すか、誤ったパスワードのままでも SUPABASE_DB_PASSWORD が優先されます。
# export SUPABASE_DB_PASSWORD='Database のパスワード'
# export SUPABASE_DATABASE_URL='postgresql://postgres.[project-ref]@aws-0-[region].pooler.supabase.com:5432/postgres'

# 本番では Origin 制限を推奨（カンマ区切り）。未設定のときはどの Origin からも POST を受け付けます。
# apex と www はどちらか一方を書けば、もう一方の Origin も許可されます（/api/contact-inquiry、/api/auth-sign-up、/api/auth-sign-in）。
CONTACT_ALLOWED_ORIGINS=https://theestablishbeauty.com,http://localhost:5173

RESEND_API_KEY=re_xxxxxxxx

# Supabase → Authentication → URL Configuration の Redirect URLs に追加:
#   {上記と同じオリジン}/auth/oauth-callback.html
# 例: https://theestablishbeauty.com/auth/oauth-callback.html , http://localhost:5173/auth/oauth-callback.html

# 会員登録完了メール（/api/auth-sign-up）内の「ログイン」リンクの起点。https まで、末尾スラッシュなし推奨。
# 未設定のときは CONTACT_ALLOWED_ORIGINS の先頭 https、または Vercel の VERCEL_URL を使います。
PUBLIC_SITE_URL=https://theestablishbeauty.com

# 登録完了メールの送信元（省略時は CONTACT_NOTIFY_FROM を使用）
# AUTH_REGISTER_EMAIL_FROM=info@theestablishbeauty.com

# Resend の送信元。theestablishbeauty.com は Resend でドメイン検証後に使う（検証前は onboarding@resend.dev のみ可・宛先も制限あり）
CONTACT_NOTIFY_FROM=info@theestablishbeauty.com

# 問い合わせ通知の宛先（Webhook → notify-contact-inquiry）
CONTACT_NOTIFY_TO=info@theestablishbeauty.com

# --- 会員登録の一覧（Table Editor）public.consumer_registrations / public.business_registrations ---
# マイグレーション: supabase/migrations/20260512140000_create_consumer_and_business_registrations.sql

# ランダムな長い文字列。Supabase Webhook の Authorization ヘッダと同じ値にする
CONTACT_WEBHOOK_SECRET=change-me-to-a-long-random-string
